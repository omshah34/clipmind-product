# ClipMind Web - Environment Variables

## NextAuth Configuration
NEXTAUTH_SECRET=your_random_secret_here_min_32_chars
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_URL_INTERNAL=http://localhost:3000

## Database
DATABASE_URL=postgresql://user:password@localhost:5432/clipmind

## OAuth Providers - GitHub
GITHUB_ID=your_github_oauth_app_id
GITHUB_SECRET=your_github_oauth_app_secret

## OAuth Providers - Google
GOOGLE_ID=your_google_oauth_app_id
GOOGLE_SECRET=your_google_oauth_app_secret

## Backend API
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_API_BASE=/api/v1

## Redis (for session store)
REDIS_URL=redis://localhost:6379

## Feature Flags
NEXT_PUBLIC_ENABLE_PREVIEW_STUDIO=true
NEXT_PUBLIC_ENABLE_PUBLISH=true
NEXT_PUBLIC_ENABLE_SEQUENCES=true
NEXT_PUBLIC_ENABLE_CONTENT_DNA=true
NEXT_PUBLIC_ENABLE_WORKSPACES=true
