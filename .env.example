# ═══════════════════════════════════════════════════════════════════════════════
# ClipMind Environment Configuration
# Copy this file to .env and fill in the values you have.
# Sections marked [OPTIONAL] can be left blank — the app will use safe fallbacks.
# ═══════════════════════════════════════════════════════════════════════════════

# ── [REQUIRED] Core AI ────────────────────────────────────────────────────────
OPENAI_API_KEY=                        # Required for transcription & clip detection

# Custom API endpoint — leave blank to use api.openai.com (default)
# Examples:
#   NVIDIA NIM : https://integrate.api.nvidia.com/v1
#   OpenRouter : https://openrouter.ai/api/v1
OPENAI_BASE_URL=

# Model to use for clip detection & caption generation
# Must be supported by whatever endpoint OPENAI_BASE_URL points to
# Examples: gpt-4o-mini, openai/gpt-oss-120b, meta/llama-3.3-70b-instruct
CLIP_DETECTOR_MODEL=gpt-4o-mini

# ── [OPTIONAL] Supabase Cloud Storage ────────────────────────────────────────
# Leave blank to use local filesystem storage (.clipmind_runtime/storage/).
# The app works fully without Supabase — files are stored on disk instead.
SUPABASE_URL=
SUPABASE_KEY=
STORAGE_BUCKET=clipmind-videos

# ── [OPTIONAL] Database ────────────────────────────────────────────────────────
# Leave BLANK to use local SQLite automatically (zero setup required).
# For production, set to a PostgreSQL URL, e.g.:
#   DATABASE_URL=postgresql://user:password@host:5432/clipmind
# Free PostgreSQL options: Neon (neon.tech), Railway, Supabase, Render
DATABASE_URL=

# ── [REQUIRED] Cache / Task Queue ─────────────────────────────────────────────
# Redis is required for Celery background workers.
# Install Redis locally: https://redis.io/docs/getting-started/
REDIS_URL=redis://localhost:6379/0

# Socket timeout settings (in seconds) - increase for slow/remote Redis
# Default: 30s - suitable for local Redis
# For Upstash/remote: consider 45-60s
REDIS_SOCKET_TIMEOUT=30
REDIS_SOCKET_CONNECT_TIMEOUT=30

# ── Pipeline Limits ────────────────────────────────────────────────────────────
CLIP_PROMPT_VERSION=v1
MAX_UPLOAD_SIZE_MB=2048
MAX_VIDEO_DURATION_MINUTES=90
TRANSCRIPT_CHUNK_MINUTES=5
TRANSCRIPT_CHUNK_OVERLAP_SECONDS=60
POLLING_INTERVAL_SECONDS=4

# ── [OPTIONAL] Authentication (NextAuth) ──────────────────────────────────────
# Required only if the frontend uses NextAuth for OAuth login.
NEXTAUTH_SECRET=your-strong-random-secret-here
NEXTAUTH_URL=http://localhost:3000

# ── [OPTIONAL] Stripe Billing ──────────────────────────────────────────────────
# Leave all blank if you do not have a Stripe account.
# Billing endpoints will return HTTP 503 gracefully when not configured.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_BUSINESS=

# ── [OPTIONAL] TikTok API ──────────────────────────────────────────────────────
# No server-side keys needed. TikTok credentials (access_token, open_id)
# are provided per-user at publish time via their connected TikTok account tokens.

# ── [OPTIONAL] YouTube / Google OAuth ─────────────────────────────────────────
# No server-side keys needed. YouTube OAuth credentials (client_id, client_secret)
# are provided per-user at publish time via their connected Google account tokens.

# ── [OPTIONAL] Instagram / Facebook Graph API ─────────────────────────────────
# No server-side keys needed. Instagram credentials (access_token, account_id)
# are provided per-user at publish time via their connected Instagram account tokens.

# ── CORS ───────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
